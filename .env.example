# Django
DJANGO_SETTINGS_MODULE=sungrid.settings.dev
DJANGO_SECRET_KEY=replace-me-with-django-secret-key
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# Database
DB_PATH=/data/db.sqlite3

# Redis
REDIS_URL=redis://redis:6379/0

# Session timeouts (seconds)
SESSION_AGE_OPERATOR=1800
SESSION_AGE_SUPERADMIN=900

# Maneuver
MANEUVER_COOLDOWN_SECONDS=30
MANEUVER_MUTEX_TTL_SECONDS=60
MANEUVER_TUNNEL_PING_TIMEOUT=1
